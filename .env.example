# Required
ANTHROPIC_API_KEY=sk-ant-...
GITHUB_TOKEN=ghp_...

# WhatsApp (via Evolution API)
ENABLE_WHATSAPP=false
EVOLUTION_API_URL=http://localhost:8084
EVOLUTION_API_KEY=your_api_key_here
EVOLUTION_INSTANCE=codespar
WHATSAPP_WEBHOOK_PORT=3001
WHATSAPP_BOT_MENTION=@codespar
# Webhook URL Evolution API POSTs inbound events to. Leave WHATSAPP_WEBHOOK_URL
# blank to derive from WHATSAPP_WEBHOOK_HOST + WHATSAPP_WEBHOOK_PORT. In compose
# set WHATSAPP_WEBHOOK_HOST to the runtime service name (e.g. "core").
WHATSAPP_WEBHOOK_URL=
WHATSAPP_WEBHOOK_HOST=host.docker.internal
# Webhook security (F10.M3 / #364). Set EVOLUTION_WEBHOOK_SECRET to a strong
# random value in production; share the same value with the evolution-api
# service. When STRICT_MODE=true the route rejects unsigned requests with 401
# even if the secret is unset (production failsafe).
EVOLUTION_WEBHOOK_SECRET=
WHATSAPP_WEBHOOK_STRICT_MODE=false
# Idle TTL for durable per-(project, channelUser) sessions, in days. The
# bridge closes sessions whose lastActivityAt is older than this on next lookup
# (F10.M4 / #366). Default 30.
WHATSAPP_SESSION_IDLE_TTL_DAYS=30

# Optional: Slack
ENABLE_SLACK=false
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...

# Optional: Telegram
ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=

# Optional: Discord
ENABLE_DISCORD=false
DISCORD_BOT_TOKEN=

# Database (auto-configured in Docker)
DATABASE_URL=postgres://codespar:codespar_dev@localhost:5432/codespar
REDIS_URL=redis://localhost:6379

# Server
PORT=3000

# Working directory for Claude Code (defaults to process.cwd())
CODESPAR_WORK_DIR=

# Default project name
PROJECT_NAME=default
